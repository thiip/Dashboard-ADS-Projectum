# Copie este arquivo para .env e preencha os valores

# Token de acesso da Meta (System User Token ou User Token com ads_read, ads_management)
# Gere em: business.facebook.com > Configurações > Usuários do Sistema > Token
META_ACCESS_TOKEN=SEU_TOKEN_AQUI

# ID da conta de anúncios (sem o prefixo "act_")
META_ACCOUNT_ID=1917726750804
